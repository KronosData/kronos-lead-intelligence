# Kronos Lead Intelligence — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git — it is excluded via .gitignore (.env*)

# ─── Database ────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string.
# For LOCAL development: use the direct connection (port 5432)
# For PRODUCTION (Vercel): use the Supabase Pooler URL (port 6543, Transaction mode)
#
# Find both URLs in: Supabase Dashboard → Project Settings → Database → Connection string
#
# Direct (local):
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
#
# Pooler (production — replace the line above in Vercel environment variables):
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
