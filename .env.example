# Kronos Lead Intelligence — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git — it is excluded via .gitignore (.env*)

# ─── Database ────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string.
# LOCAL development: direct connection (port 5432)
# PRODUCTION (Vercel): Supabase Pooler URL (port 6543, Transaction mode)
#
# Find both in: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ─── Supabase Auth ───────────────────────────────────────────────────────────
# Find in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ─── Authorization ───────────────────────────────────────────────────────────
# Comma-separated list of authorized email addresses.
# Only users whose email appears here can access the dashboard.
# Add future team members by appending: user1@domain.com,user2@domain.com
AUTHORIZED_EMAILS=alejandro@kronosdata.tech
