# Kronos Lead Intelligence — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git — it is excluded via .gitignore (.env*)

# ─── Database ────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string.
# LOCAL development: direct connection (port 5432)
# PRODUCTION (Vercel): Supabase Pooler URL (port 6543, Transaction mode)
#
# Find both in: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ─── Supabase (database client — NOT used for login) ─────────────────────────
# Find in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ─── Internal Access (server-side only — NEVER use NEXT_PUBLIC_ prefix) ──────
# Comma-separated list of authorized email addresses.
AUTHORIZED_EMAILS=alejandro@kronosdata.tech

# Hashed password for internal access.
# NEVER store the plain password here. Generate the hash locally:
#   node scripts/hash-password.mjs
# This variable is server-side only and never reaches the browser bundle.
INTERNAL_ACCESS_PASSWORD_HASH=scrypt:65536:8:1:YOUR_SALT_HEX:YOUR_HASH_HEX

# ─── Session ─────────────────────────────────────────────────────────────────
# 64-byte hex secret for signing session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# This variable is server-side only and never reaches the browser bundle.
SESSION_SECRET=YOUR_SESSION_SECRET
