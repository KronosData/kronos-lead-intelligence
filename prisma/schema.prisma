generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id                String    @id @default(uuid())
  name              String
  industry          String
  country           String
  city              String?
  website           String?
  whatsapp          String?
  instagram         String?
  linkedin          String?
  googleBusinessUrl String?   @map("google_business_url")
  status            String    @default("active")
  leadSource        String?   @map("lead_source")

  // Denormalized — updated atomically on every new evaluation insert
  latestOpportunityScore Int       @default(0) @map("latest_opportunity_score")
  latestPriorityLevel    String    @default("low") @map("latest_priority_level")
  latestEvaluatedAt      DateTime? @map("latest_evaluated_at")
  latestPackageSlug      String?   @map("latest_package_slug")
  latestPrimaryService   String?   @map("latest_primary_service")
  latestScoreConfidence  String?   @map("latest_score_confidence")

  // Phase 3.8 — Prospect Fit Score (discovery-stage, before web analysis)
  prospectFitScore        Int?    @map("prospect_fit_score")
  salesPriorityScore      Int?    @map("sales_priority_score")
  estimatedBusinessSize   String? @map("estimated_business_size")
  businessSizeConfidence  String? @map("business_size_confidence")
  chainDetected           Boolean @default(false) @map("chain_detected")
  prospectProfile         String? @map("prospect_profile")
  contactabilityScore     Int?    @map("contactability_score")
  opportunityReasons      String[] @map("opportunity_reasons")
  prospectRisks           String[] @map("prospect_risks")

  // Phase 3.8 — Discovery provenance
  discoverySearchCountry  String? @map("discovery_search_country")
  discoverySearchCity     String? @map("discovery_search_city")
  discoverySearchDistrict String? @map("discovery_search_district")
  discoveryMode           String? @map("discovery_mode")
  discoveryRankBefore     Int?    @map("discovery_rank_before")
  discoveryRankAfter      Int?    @map("discovery_rank_after")

  // Phase 3.9 — Commercial qualification
  entityType              String? @map("entity_type")
  entityIsCommercial      Boolean @default(true) @map("entity_is_commercial")
  entityExclusionReason   String? @map("entity_exclusion_reason")
  commercialQualification String? @map("commercial_qualification")
  salesQualificationScore Int?    @map("sales_qualification_score")
  sellabilityClass        String? @map("sellability_class")
  roiFitScore             Int?    @map("roi_fit_score")
  roiFitLabel             String? @map("roi_fit_label")
  roiMultiple             Float?  @map("roi_multiple")
  paybackMonths           Int?    @map("payback_months")
  budgetCapacityScore     Int?    @map("budget_capacity_score")
  budgetCapacityLabel     String? @map("budget_capacity_label")
  economicModelType       String? @map("economic_model_type")
  primaryProblem          String? @map("primary_problem")
  whyContact              String[] @map("why_contact")
  whyNotContact           String[] @map("why_not_contact")
  qualificationQuestions  String[] @map("qualification_questions")

  // Phase 4 — Composite scoring model (multi-dimensional)
  icpFitScore            Int?    @map("icp_fit_score")            // 0-100 ICP alignment
  painScore              Int?    @map("pain_score")               // 0-100 commercial pain visibility
  paymentCapacityScore   Int?    @map("payment_capacity_score")   // 0-100 inferred payment capacity
  evidenceCoverageScore  Int?    @map("evidence_coverage_score")  // 0-100 evidence quality
  commercialIntentScore  Int?    @map("commercial_intent_score")  // 0-100 digital investment signals
  salesOpportunityScore  Int?    @map("sales_opportunity_score")  // 0-100 master composite score
  evidenceTier           String? @map("evidence_tier")            // HIGH | MEDIUM | LOW
  salesPriority          String? @map("sales_priority")           // HOT | HIGH | MEDIUM | LOW | REVIEW | DISCARD
  qualificationReason    String? @map("qualification_reason")     // 1-2 sentence positive reason
  disqualificationReason String? @map("disqualification_reason")  // why not commercial/qualified
  recommendedFirstAction String? @map("recommended_first_action") // immediate next step

  // Evidence qualification — website identity + commercial state
  websiteVerificationStatus String? @default("NOT_PROVIDED") @map("website_verification_status")
  websiteVerifiedAt          DateTime? @map("website_verified_at")
  commercialState            String?   @map("commercial_state")

  // Phase 4 — Direct contact info (denormalized for quick outreach)
  contactName      String?   @map("contact_name")
  contactRole      String?   @map("contact_role")
  contactPhone     String?   @map("contact_phone")
  contactEmail     String?   @map("contact_email")
  preferredChannel String?   @map("preferred_channel")   // whatsapp | email | linkedin | call

  // Phase 4 — Compliance & data provenance
  doNotContact    Boolean   @default(false) @map("do_not_contact")
  optOut          Boolean   @default(false) @map("opt_out")
  dataSource      String?   @map("data_source")
  dataCollectedAt DateTime? @map("data_collected_at")
  legalRisk       String?   @map("legal_risk")   // LOW | MEDIUM | HIGH

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  evaluations     Evaluation[]
  salesNotes      SalesNote[]
  outreachHistory OutreachHistory[]
  outreachDrafts  OutreachDraft[]
  audits          Audit[]

  @@map("companies")
}

model Evaluation {
  id          String @id @default(uuid())
  companyId   String @map("company_id")
  evaluatedBy String @map("evaluated_by")

  // Signals (15 boolean flags)
  // Absence of good things = FALSE = opportunity
  // Presence of bad things = TRUE  = opportunity
  signalHasWebsite           Boolean @default(false) @map("signal_has_website")
  signalHasWhatsapp          Boolean @default(false) @map("signal_has_whatsapp")
  signalHasContactForm       Boolean @default(false) @map("signal_has_contact_form")
  signalHasBookingSystem     Boolean @default(false) @map("signal_has_booking_system")
  signalHasInstagram         Boolean @default(false) @map("signal_has_instagram")
  signalHasLinkedin          Boolean @default(false) @map("signal_has_linkedin")
  signalHasGoogleBusiness    Boolean @default(false) @map("signal_has_google_business")
  signalHasReviews           Boolean @default(false) @map("signal_has_reviews")
  signalHasUnansweredReviews Boolean @default(false) @map("signal_has_unanswered_reviews")
  signalHasClearCta          Boolean @default(false) @map("signal_has_clear_cta")
  signalHasLeadCapture       Boolean @default(false) @map("signal_has_lead_capture")
  signalSlowResponse         Boolean @default(false) @map("signal_slow_response")
  signalWeakFollowup         Boolean @default(false) @map("signal_weak_followup")
  signalManualWork           Boolean @default(false) @map("signal_manual_work")
  signalWeakOnlinePresence   Boolean @default(false) @map("signal_weak_online_presence")

  // Computed scores (0–100)
  scoreLeadGeneration        Int? @map("score_lead_generation")
  scoreFollowUp              Int? @map("score_follow_up")
  scoreConversionProcess     Int? @map("score_conversion_process")
  scoreAutomationOpportunity Int? @map("score_automation_opportunity")
  scoreOnlinePresence        Int? @map("score_online_presence")
  scoreReputation            Int? @map("score_reputation")
  opportunityScore           Int? @map("opportunity_score")

  // Diagnosis
  priorityLevel       String?  @map("priority_level")
  detectedProblems    String[] @map("detected_problems")
  probablePainPoint   String?  @map("probable_pain_point")
  recommendedSolution String?  @map("recommended_solution")
  estimatedValueMin   Int?     @map("estimated_value_min")
  estimatedValueMax   Int?     @map("estimated_value_max")

  // Revenue Opportunity Module
  estimatedLeadsLostPerMonth   Int? @map("estimated_leads_lost_per_month")
  estimatedRevenueLostPerMonth Int? @map("estimated_revenue_lost_per_month")
  estimatedRoiPotential        Int? @map("estimated_roi_potential")

  // Service Match Engine
  recommendedServices        String[]  @map("recommended_services")
  implementationDifficulty   String?   @map("implementation_difficulty")
  implementationTimeEstimate String?   @map("implementation_time_estimate")
  estimatedProjectPriceMin   Int?      @map("estimated_project_price_min")
  estimatedProjectPriceMax   Int?      @map("estimated_project_price_max")

  // Tiered service recommendations
  primaryService        String?  @map("primary_service")
  complementaryServices String[] @map("complementary_services")
  futureServices        String[] @map("future_services")
  priceLabel            String?  @map("price_label")

  // Evidence and quality
  signalEvidence    Json?   @map("signal_evidence")
  researchCoverage  Int?    @map("research_coverage")
  scoreConfidence   String? @map("score_confidence")
  evaluationStatus  String? @map("evaluation_status")
  isLowCoverageHold Boolean @default(false) @map("is_low_coverage_hold")
  evaluationSource  String? @default("manual") @map("evaluation_source")

  // v2 — legacy flag: evaluations with ROI/revenue/diagnosis without real evidence
  isLegacyEval  Boolean @default(false) @map("is_legacy_eval")
  legacyReason  String? @map("legacy_reason")

  // Package recommendation (Kronos official packages)
  recommendedPackageSlug  String?  @map("recommended_package_slug")
  recommendedPackageName  String?  @map("recommended_package_name")
  alternativePackageSlug  String?  @map("alternative_package_slug")
  alternativePackageName  String?  @map("alternative_package_name")
  packageReason           String?  @map("package_reason")
  packageEvidence         String[] @map("package_evidence")
  packageConfidence       String?  @map("package_confidence")
  packageCoverage         Int?     @map("package_coverage")
  packagePriceMin         Int?     @map("package_price_min")
  packagePriceMax         Int?     @map("package_price_max")
  packageTimelineMin      Int?     @map("package_timeline_min")
  packageTimelineMax      Int?     @map("package_timeline_max")
  officialSourceUrl       String?  @map("official_source_url")
  catalogVersion          String?  @map("catalog_version")

  evaluatedAt DateTime @default(now()) @map("evaluated_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, evaluatedAt(sort: Desc)])
  @@map("evaluations")
}

model SalesNote {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  contactName  String? @map("contact_name")
  contactRole  String? @map("contact_role")
  contactPhone String? @map("contact_phone")
  contactEmail String? @map("contact_email")

  // CRM pipeline stage (expanded 14-stage funnel)
  // discovered | evaluated | manual_review | approved_for_contact
  // contacted | responded | audit_scheduled | audit_completed
  // proposal_sent | negotiating | won | lost | nurturing | discarded
  pipelineStage String @default("discovered") @map("pipeline_stage")

  // not_contacted | attempted | contacted | in_conversation
  // proposal_sent | negotiating | closed_won | closed_lost
  contactStatus String @default("not_contacted") @map("contact_status")

  // not_scheduled | scheduled | completed | no_show | rescheduled
  meetingStatus String    @default("not_scheduled") @map("meeting_status")
  meetingDate   DateTime? @map("meeting_date")
  meetingNotes  String?   @map("meeting_notes")

  budgetMin         Int?    @map("budget_min")
  budgetMax         Int?    @map("budget_max")
  budgetCurrency    String  @default("USD") @map("budget_currency")
  objections        String?
  followUpNotes     String? @map("follow_up_notes")
  salesObservations String? @map("sales_observations")

  nextAction     String?   @map("next_action")
  nextActionDate DateTime? @map("next_action_date")
  assignedTo     String?   @map("assigned_to")

  closeProbability  Int?    @map("close_probability")
  potentialValue    Int?    @map("potential_value")      // USD estimate
  proposedPackageSlug String? @map("proposed_package_slug")
  proposedServiceSlug String? @map("proposed_service_slug")
  preferredChannel  String? @map("preferred_channel")   // whatsapp | email | linkedin | call
  lostReason        String? @map("lost_reason")
  internalNotes     String? @map("internal_notes")
  activityLog       Json?   @map("activity_log")        // [{date, action, note}]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("sales_notes")
}

model OutreachHistory {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  // linkedin | email | whatsapp | instagram | call | other
  channel     String
  messageSent String?  @map("message_sent")
  sentBy      String?  @map("sent_by")
  sentAt      DateTime @default(now()) @map("sent_at")

  // interested | not_interested | no_response
  // asked_to_follow_up | booked_call | closed_won | closed_lost
  responseReceived Boolean   @default(false) @map("response_received")
  responseType     String?   @map("response_type")
  responseNotes    String?   @map("response_notes")
  repliedAt        DateTime? @map("replied_at")

  nextFollowUpAt DateTime? @map("next_follow_up_at")

  // Future-proofing: automation, AI message tracking, multi-account
  sequenceNumber Int     @default(1) @map("sequence_number")
  templateUsed   String? @map("template_used")
  channelAccount String? @map("channel_account")
  isAutomated    Boolean @default(false) @map("is_automated")

  // Commercial alignment tracking
  packageSlug        String?  @map("package_slug")
  individualService  String?  @map("individual_service")
  evidenceLevel      String?  @map("evidence_level")
  templateType       String?  @map("template_type")
  officialUrlIncluded Boolean @default(false) @map("official_url_included")
  catalogVersion     String?  @map("catalog_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([sentAt])
  @@index([channel])
  @@index([responseType])
  @@index([nextFollowUpAt])
  @@map("outreach_history")
}

// Phase 4 — Generated outreach message drafts (pre-send queue)
model OutreachDraft {
  id           String  @id @default(uuid())
  companyId    String  @map("company_id")
  channel      String  // email | whatsapp | linkedin
  evidenceTier String? @map("evidence_tier")  // HIGH | MEDIUM | LOW
  subject      String? // email only
  body         String  @db.Text
  version      Int     @default(1)

  // draft | queued | copied | discarded
  status   String    @default("draft")
  copiedAt DateTime? @map("copied_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([channel])
  @@map("outreach_drafts")
}

// Phase 4 — Free audit / diagnostic flow
model Audit {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  createdBy String? @map("created_by")

  // draft | in_progress | completed | converted_to_proposal
  status String @default("draft")
  sector String?

  // JSON array: [{id, item, status: "pending"|"confirmed"|"not_applicable"|"flagged", notes}]
  checklist Json?

  findings           String? @db.Text
  confirmedProblems  String[] @map("confirmed_problems")
  hypothesis         String? @db.Text
  validatedDiagnosis String? @map("validated_diagnosis") @db.Text
  qualificationQuestions String[] @map("qualification_questions")

  recommendedPackageSlug  String? @map("recommended_package_slug")
  recommendedServiceSlug  String? @map("recommended_service_slug")
  packageReason           String? @map("package_reason") @db.Text

  meetingSummary String? @map("meeting_summary") @db.Text
  meetingDate    DateTime? @map("meeting_date")

  convertedToProposal Boolean   @default(false) @map("converted_to_proposal")
  convertedAt         DateTime? @map("converted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("audits")
}
